import React, { useState, useMemo, useEffect } from 'react';
import { 
  PlusCircle, 
  ArrowUpCircle, 
  ArrowDownCircle, 
  PiggyBank, 
  Wallet, 
  Trash2, 
  PieChart, 
  Calendar,
  CreditCard,
  TrendingUp,
  Save,
  CloudUpload,
  Settings,
  CheckCircle2,
  AlertCircle
} from 'lucide-react';

const App = () => {
  // --- PERSISTENCIA LOCAL ---
  const loadInitialTransactions = () => {
    const saved = localStorage.getItem('finance_transactions');
    if (saved) return JSON.parse(saved);
    return [
      { id: 1, date: '2024-03-01', desc: 'Salario Inicial', category: 'Sueldo', type: 'Ingreso', source: 'Nómina', amount: 3000 },
    ];
  };

  const loadInitialTarget = () => {
    const saved = localStorage.getItem('finance_target_percent');
    return saved ? parseInt(saved) : 20;
  };

  const [transactions, setTransactions] = useState(loadInitialTransactions);
  const [savingTargetPercent, setSavingTargetPercent] = useState(loadInitialTarget);
  const [sheetUrl, setSheetUrl] = useState(localStorage.getItem('finance_sheet_url') || '');
  const [syncStatus, setSyncStatus] = useState('idle'); // 'idle', 'loading', 'success', 'error'

  useEffect(() => {
    localStorage.setItem('finance_transactions', JSON.stringify(transactions));
  }, [transactions]);

  useEffect(() => {
    localStorage.setItem('finance_target_percent', savingTargetPercent.toString());
  }, [savingTargetPercent]);

  useEffect(() => {
    localStorage.setItem('finance_sheet_url', sheetUrl);
  }, [sheetUrl]);

  const [formData, setFormData] = useState({
    date: new Date().toISOString().split('T')[0],
    desc: '',
    category: 'Vivienda',
    type: 'Gasto',
    source: 'Banco',
    amount: ''
  });

  // --- LÓGICA DE EXPORTACIÓN A GOOGLE SHEETS ---
  const exportToSheets = async () => {
    if (!sheetUrl) {
      alert("Por favor, configura la URL de tu Google Apps Script en la sección de ajustes.");
      return;
    }

    setSyncStatus('loading');
    try {
      // Enviamos el array completo de transacciones
      const response = await fetch(sheetUrl, {
        method: 'POST',
        mode: 'no-cors', // Importante para scripts de Google
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(transactions)
      });
      
      setSyncStatus('success');
      setTimeout(() => setSyncStatus('idle'), 3000);
    } catch (error) {
      console.error("Error al sincronizar:", error);
      setSyncStatus('error');
      setTimeout(() => setSyncStatus('idle'), 3000);
    }
  };

  // Cálculos financieros
  const totals = useMemo(() => {
    const income = transactions.filter(t => t.type === 'Ingreso').reduce((acc, t) => acc + t.amount, 0);
    const expenses = transactions.filter(t => t.type === 'Gasto').reduce((acc, t) => acc + t.amount, 0);
    const actualSavings = transactions.filter(t => t.type === 'Ahorro').reduce((acc, t) => acc + t.amount, 0);
    const targetSavingsAmount = (income * savingTargetPercent) / 100;
    const remainingToTarget = Math.max(0, targetSavingsAmount - actualSavings);
    const available = income - expenses - actualSavings;

    return { income, expenses, actualSavings, targetSavingsAmount, remainingToTarget, available };
  }, [transactions, savingTargetPercent]);

  const categoryData = useMemo(() => {
    const expensesOnly = transactions.filter(t => t.type === 'Gasto');
    const categories = {};
    expensesOnly.forEach(t => {
      categories[t.category] = (categories[t.category] || 0) + t.amount;
    });
    return Object.entries(categories).map(([name, value]) => ({ name, value }));
  }, [transactions]);

  const addTransaction = (e) => {
    e.preventDefault();
    if (!formData.amount || !formData.desc) return;
    const newTransaction = { ...formData, id: Date.now(), amount: parseFloat(formData.amount) };
    setTransactions([newTransaction, ...transactions]);
    setFormData({ ...formData, desc: '', amount: '' });
  };

  const deleteTransaction = (id) => {
    if (window.confirm('¿Eliminar este registro?')) {
      setTransactions(transactions.filter(t => t.id !== id));
    }
  };

  return (
    <div className="min-h-screen bg-slate-50 p-4 md:p-8 font-sans text-slate-900">
      <header className="max-w-6xl mx-auto mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 className="text-3xl font-bold text-indigo-700">Mi Control Financiero</h1>
          <p className="text-slate-500 flex items-center gap-2 text-sm">
            <Save size={14} /> Guardado local activado
          </p>
        </div>
        
        <div className="flex flex-wrap gap-3">
          <button 
            onClick={exportToSheets}
            disabled={syncStatus === 'loading'}
            className={`flex items-center gap-2 px-4 py-2 rounded-xl font-bold text-sm transition-all shadow-sm ${
              syncStatus === 'success' ? 'bg-emerald-500 text-white' : 
              syncStatus === 'error' ? 'bg-rose-500 text-white' : 
              'bg-white text-slate-700 hover:bg-slate-50 border border-slate-200'
            }`}
          >
            {syncStatus === 'loading' ? 'Sincronizando...' : 
             syncStatus === 'success' ? <><CheckCircle2 size={16}/> ¡Guardado!</> :
             syncStatus === 'error' ? <><AlertCircle size={16}/> Error</> :
             <><CloudUpload size={16} className="text-indigo-600"/> Sincronizar Hoja de Cálculo</>}
          </button>
          
          <div className="bg-white px-4 py-2 rounded-xl shadow-sm border border-slate-200 flex items-center gap-4">
            <label className="text-xs font-bold text-slate-400 uppercase tracking-tighter">Ahorro:</label>
            <input 
              type="range" min="0" max="100" value={savingTargetPercent} 
              onChange={(e) => setSavingTargetPercent(parseInt(e.target.value))}
              className="w-24 h-1.5 bg-indigo-100 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
            <span className="font-bold text-indigo-600 w-8">{savingTargetPercent}%</span>
          </div>
        </div>
      </header>

      <main className="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        {/* Resumen */}
        <div className="lg:col-span-3 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <StatCard title="Ingresos" value={totals.income} icon={<ArrowUpCircle className="text-emerald-500" />} color="border-emerald-500" />
          <StatCard title="Gastos" value={totals.expenses} icon={<ArrowDownCircle className="text-rose-500" />} color="border-rose-500" />
          <StatCard title="Ahorro Real" value={totals.actualSavings} subtitle={`Meta: $${totals.targetSavingsAmount.toFixed(0)}`} icon={<PiggyBank className="text-amber-500" />} color="border-amber-500" />
          <StatCard title="Disponible" value={totals.available} icon={<Wallet className="text-indigo-500" />} color="border-indigo-500" highlight={totals.available < 0} />
        </div>

        <div className="space-y-8">
          {/* Formulario */}
          <section className="bg-white p-6 rounded-3xl shadow-sm border border-slate-200">
            <h2 className="text-xl font-bold mb-6 flex items-center gap-2">
              <PlusCircle size={20} className="text-indigo-600" /> Nuevo Registro
            </h2>
            <form onSubmit={addTransaction} className="space-y-4">
              <input 
                type="text" className="w-full p-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none"
                placeholder="Descripción" value={formData.desc} onChange={(e) => setFormData({...formData, desc: e.target.value})} required
              />
              <div className="grid grid-cols-2 gap-4">
                <input 
                  type="number" step="0.01" className="w-full p-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none"
                  placeholder="Monto" value={formData.amount} onChange={(e) => setFormData({...formData, amount: e.target.value})} required
                />
                <select className="w-full p-3 rounded-xl border border-slate-200 bg-white" value={formData.type} onChange={(e) => setFormData({...formData, type: e.target.value})}>
                  <option value="Ingreso">Ingreso</option>
                  <option value="Gasto">Gasto</option>
                  <option value="Ahorro">Ahorro</option>
                </select>
              </div>
              <select className="w-full p-3 rounded-xl border border-slate-200 bg-white" value={formData.category} onChange={(e) => setFormData({...formData, category: e.target.value})}>
                <option value="Sueldo">Sueldo</option>
                <option value="Vivienda">Vivienda</option>
                <option value="Alimentación">Alimentación</option>
                <option value="Transporte">Transporte</option>
                <option value="Ocio">Ocio</option>
                <option value="Inversión">Inversión</option>
                <option value="Otros">Otros</option>
              </select>
              <div className="grid grid-cols-2 gap-4">
                <input type="date" className="w-full p-3 rounded-xl border border-slate-200" value={formData.date} onChange={(e) => setFormData({...formData, date: e.target.value})} />
                <input type="text" className="w-full p-3 rounded-xl border border-slate-200" placeholder="Cuenta" value={formData.source} onChange={(e) => setFormData({...formData, source: e.target.value})} />
              </div>
              <button type="submit" className="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl shadow-lg transition-all">
                Agregar Registro
              </button>
            </form>
          </section>

          {/* Ajustes de Sincronización */}
          <section className="bg-slate-800 text-slate-100 p-6 rounded-3xl shadow-lg">
            <h2 className="text-lg font-bold mb-4 flex items-center gap-2">
              <Settings size={18} className="text-indigo-400" /> Configurar Hoja de Cálculo
            </h2>
            <p className="text-xs text-slate-400 mb-4">
              Pega aquí la URL de tu Google Apps Script para respaldar tus datos en la nube.
            </p>
            <input 
              type="text" 
              placeholder="https://script.google.com/macros/s/..." 
              className="w-full p-3 rounded-xl bg-slate-700 border border-slate-600 text-sm outline-none focus:ring-2 focus:ring-indigo-400"
              value={sheetUrl}
              onChange={(e) => setSheetUrl(e.target.value)}
            />
          </section>
        </div>

        <div className="lg:col-span-2 space-y-4">
          {/* Historial */}
          <h2 className="text-xl font-bold flex items-center gap-2 mb-2">
            <Calendar size={20} className="text-indigo-600" /> Historial
          </h2>
          <div className="space-y-3 max-h-[500px] overflow-y-auto pr-2 custom-scrollbar">
            {transactions.map(t => (
              <div key={t.id} className="group bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between transition-all hover:border-indigo-200">
                <div className="flex items-center gap-4">
                  <div className={`p-3 rounded-xl ${t.type === 'Ingreso' ? 'bg-emerald-50 text-emerald-600' : t.type === 'Ahorro' ? 'bg-amber-50 text-amber-600' : 'bg-rose-50 text-rose-600'}`}>
                    {t.type === 'Ingreso' ? <ArrowUpCircle size={22} /> : t.type === 'Ahorro' ? <PiggyBank size={22} /> : <ArrowDownCircle size={22} />}
                  </div>
                  <div>
                    <h4 className="font-bold text-slate-800">{t.desc}</h4>
                    <span className="text-xs text-slate-400 font-medium">{t.category} • {t.source} • {t.date}</span>
                  </div>
                </div>
                <div className="flex items-center gap-4">
                  <div className={`text-right ${t.type === 'Ingreso' ? 'text-emerald-600' : t.type === 'Ahorro' ? 'text-amber-600' : 'text-rose-600'}`}>
                    <span className="text-lg font-black">{t.type === 'Ingreso' ? '+' : '-'}${t.amount.toLocaleString()}</span>
                  </div>
                  <button onClick={() => deleteTransaction(t.id)} className="p-2 text-slate-300 hover:text-rose-500 opacity-0 group-hover:opacity-100 transition-all">
                    <Trash2 size={16} />
                  </button>
                </div>
              </div>
            ))}
          </div>

          {/* Salud Financiera */}
          <section className="bg-indigo-900 text-white p-6 rounded-3xl shadow-xl relative overflow-hidden">
            <div className="relative z-10">
              <h3 className="text-lg font-bold mb-2 flex items-center gap-2"><TrendingUp size={20} className="text-indigo-300"/> Progreso de Ahorro</h3>
              <div className="w-full bg-indigo-800 h-3 rounded-full mb-2">
                <div className="bg-indigo-400 h-full rounded-full transition-all duration-700" style={{ width: `${Math.min(100, (totals.actualSavings / totals.targetSavingsAmount) * 100 || 0)}%` }}></div>
              </div>
              <div className="flex justify-between text-[10px] font-bold uppercase text-indigo-300">
                <span>0%</span>
                <span>Objetivo: ${totals.targetSavingsAmount.toFixed(0)}</span>
              </div>
            </div>
            <PiggyBank size={120} className="absolute -right-6 -bottom-6 text-indigo-800 opacity-30" />
          </section>
        </div>
      </main>

      <style>{`.custom-scrollbar::-webkit-scrollbar { width: 4px; } .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }`}</style>
    </div>
  );
};

const StatCard = ({ title, value, icon, color, subtitle, highlight }) => (
  <div className={`bg-white p-5 rounded-2xl shadow-sm border-b-4 ${color}`}>
    <div className="flex justify-between items-start mb-2">
      <span className="text-[10px] font-bold text-slate-400 uppercase">{title}</span>
      {icon}
    </div>
    <div className={`text-xl font-black ${highlight ? 'text-rose-600' : 'text-slate-800'}`}>
      ${value.toLocaleString(undefined, { minimumFractionDigits: 2 })}
    </div>
    {subtitle && <div className="text-[10px] text-slate-400 font-medium">{subtitle}</div>}
  </div>
);

export default App;
